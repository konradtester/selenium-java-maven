# Base URL of the application under test.
# The example below points at a public demo site so the starter works out of the box.
BASE_URL=https://the-internet.herokuapp.com

# Base URL for API/REST tests (e2e.steps.ApiSteps). Falls back to BASE_URL if not set.
# The example below points at a public demo API so the starter works out of the box.
API_BASE_URL=https://jsonplaceholder.typicode.com

# Demo credentials used by the sample login scenario.
USERNAME=tomsmith
PASSWORD=SuperSecretPassword!

# Template used to generate a unique email address per test run (see {{test_email}}).
EMAIL_TEMPLATE=test+{{random}}@example.com

# Optional: mailbox used for tests that verify emails via IMAP (registration, password reset, etc.)
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
